# Normalize all text to LF in the repo. Working tree uses native EOL on checkout
# when core.autocrlf is set; with `eol=lf` the repo copy is always LF regardless.
* text=auto eol=lf

# Explicit binary types (no EOL conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.xlsx binary
*.xls binary
*.zip binary
*.gz binary
